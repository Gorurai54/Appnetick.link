{
"cleanUrls": true,
"rewrites": [
{
"source": "/post/:id",
"destination": "/post.html"
},
{
  "source": "/user/channel/invite/uid",
  "destination": "/api/channel.js"
},
{
"source": "/user/profile",
"destination": "/api/profile"
},
{
"source": "/auth/user/login",
"destination": "/auth/user/login.html"
},
{
"source": "/auth/user/signup",
"destination": "/auth/user/signup.html"
},
{
"source": "/user/terms-and-conditions",
"destination": "/user/terms-and-conditions.html"
}
]
}
