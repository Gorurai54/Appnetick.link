{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/post/:id",
      "destination": "/post.html"
    },
    {
      "source": "/user/profile",
      "destination": "/api/profile.js"
    },
    {
      "source": "/auth/user/login",
      "destination": "/auth/user/login.html"
    },
    {
      "source": "/auth/user/signup",
      "destination": "/auth/user/signup.html"
    }
     {
      "source": "/conditions/user/terms-and-conditions",
      "destination": "/conditions/user/terms-and-conditions.html"
     }
  ]
}
